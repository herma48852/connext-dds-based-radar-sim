{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vs2022-x64",
      "displayName": "Windows VS 2022 x64 (full Connext build)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-x64",
      "toolchainFile": "${sourceDir}/cmake/toolchain-windows-msvc.cmake",
      "cacheVariables": {
        "RADAR_BUILD_APPLICATIONS": "ON",
        "RADAR_BUILD_UI_TESTS": "ON",
        "BUILD_TESTING": "ON",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/windows-x64"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-portable",
      "displayName": "Windows VS 2022 x64 (portable tests only)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-portable",
      "toolchainFile": "${sourceDir}/cmake/toolchain-windows-msvc.cmake",
      "cacheVariables": {
        "RADAR_BUILD_APPLICATIONS": "OFF",
        "RADAR_BUILD_UI_TESTS": "ON",
        "BUILD_TESTING": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS arm64 (full Connext build)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/macos-arm64",
      "toolchainFile": "${sourceDir}/cmake/toolchain-macos-arm64.cmake",
      "cacheVariables": {
        "RADAR_BUILD_APPLICATIONS": "ON",
        "RADAR_BUILD_UI_TESTS": "ON",
        "BUILD_TESTING": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-relwithdebinfo",
      "configurePreset": "windows-vs2022-x64",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-vs2022-x64",
      "configuration": "Debug"
    },
    {
      "name": "windows-portable-relwithdebinfo",
      "configurePreset": "windows-portable",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "macos-relwithdebinfo",
      "configurePreset": "macos-arm64"
    }
  ],
  "testPresets": [
    {
      "name": "windows-relwithdebinfo",
      "configurePreset": "windows-vs2022-x64",
      "configuration": "RelWithDebInfo",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows-portable-relwithdebinfo",
      "configurePreset": "windows-portable",
      "configuration": "RelWithDebInfo",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "macos-relwithdebinfo",
      "configurePreset": "macos-arm64",
      "output": { "outputOnFailure": true }
    }
  ]
}
